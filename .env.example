# ==========================================
# HeraPlus Environment Variables
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ------------------------------------------
# Presage Engine (Biometrics)
# ------------------------------------------
PRESAGE_API_KEY=your_presage_api_key
PRESAGE_API_URL=https://api.presagetech.com
PRESAGE_VIDEO_API_URL=http://localhost:8080/process-video
PRESAGE_BRIDGE_PATH=

# ------------------------------------------
# Gemini AI (Diagnosis Engine)
# ------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------
# ElevenLabs (Voice / TTS)
# ------------------------------------------
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ------------------------------------------
# Supabase (Auth & Database)
# ------------------------------------------
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ------------------------------------------
# Client / Vite
# ------------------------------------------
VITE_API_BASE_URL=

# ------------------------------------------
# RapidAPI (Menstrual Cycle Insights)
# ------------------------------------------
# Get key: https://rapidapi.com → search "menstrual cycle" → subscribe → copy key
# Set RAPID_API_PATH to the exact path from the API's "Code Snippets" (e.g. /predict) if not /
RAPID_API_KEY=your_rapidapi_key_here
RAPID_API_HOST=womens-health-menstrual-cycle-phase-predictions-insights.p.rapidapi.com
# RAPID_API_PATH=/predict

# ------------------------------------------
# Server
# ------------------------------------------
PORT=3001
